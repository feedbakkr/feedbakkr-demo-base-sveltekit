{
	"name": "feedbakkr-demo-base-sveltekit",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"engines": {
		"node": ">=20"
	},
	"packageManager": "pnpm@9.15.4",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"security:audit": "pnpm audit --audit-level high",
		"security:audit:moderate": "pnpm audit --audit-level moderate",
		"security:osv": "osv-scanner --recursive .",
		"security:scan": "pnpm run security:audit && pnpm run security:osv",
		"security:scan:full": "pnpm run security:audit:moderate && pnpm run security:osv"
	},
	"devDependencies": {
		"@sveltejs/adapter-auto": "^7.0.1",
		"@sveltejs/kit": "^2.57.0",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"svelte": "^5.55.2",
		"svelte-check": "^4.4.6",
		"typescript": "^6.0.2",
		"vite": "^8.0.7"
	},
	"pnpm": {
		"overrides": {
			"devalue": ">=5.8.1"
		}
	}
}
